<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- Локальные настройки -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_local"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <!-- Заголовок аккордеона -->
                <LinearLayout
                    android:id="@+id/header_local"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Локальные настройки"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/icon_local"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_expand_more"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
                
                <!-- Содержимое аккордеона -->
                <LinearLayout
                    android:id="@+id/content_local"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="0dp"
                    android:visibility="visible">
                    
                    <!-- Аутентификация локального прокси -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Аутентификация локального прокси"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_local_proxy_user"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Логин локального прокси"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:passwordToggleEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_local_proxy_pass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Пароль локального прокси"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <!-- Локальный SOCKS5 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Локальный SOCKS5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_socks5_enabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Включить SOCKS5"
                        android:checked="true" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_socks5_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Порт SOCKS5"
                            android:inputType="number"
                            android:text="1080" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_socks5_bind_all"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Доступ из сети (0.0.0.0)"
                        android:layout_marginTop="8dp" />
                    
                    <!-- Локальный HTTP -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Локальный HTTP/HTTPS"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_http_enabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Включить HTTP/HTTPS"
                        android:checked="false" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_http_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Порт HTTP/HTTPS"
                            android:inputType="number"
                            android:text="8080" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_http_bind_all"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Доступ из сети (0.0.0.0)"
                        android:layout_marginTop="8dp" />
                    
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Прокси (upstream и проверка) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_proxy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <LinearLayout
                    android:id="@+id/header_proxy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Прокси (upstream и проверка)"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/icon_proxy"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_expand_more"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
                
                <LinearLayout
                    android:id="@+id/content_proxy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="0dp"
                    android:visibility="gone">
                    
                    <!-- SOCKS5 Upstream -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Каскадирование SOCKS5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_socks5_upstream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Использовать upstream прокси" />
                    
                    <LinearLayout
                        android:id="@+id/layout_socks5_upstream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_socks5_upstream_host"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Хост upstream прокси"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_socks5_upstream_port"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Порт upstream прокси"
                                android:inputType="number"
                                android:text="1080" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <RadioGroup
                            android:id="@+id/radio_group_socks5_upstream_protocol"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <RadioButton
                                android:id="@+id/radio_socks5_upstream_http"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="HTTP" />
                            <RadioButton
                                android:id="@+id/radio_socks5_upstream_socks5"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="SOCKS5"
                                android:checked="true" />
                        </RadioGroup>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_socks5_upstream_user"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Логин (опционально)"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:passwordToggleEnabled="true">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_socks5_upstream_pass"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Пароль (опционально)"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                    
                    <!-- HTTP Upstream -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Каскадирование HTTP/HTTPS"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_http_upstream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Использовать upstream прокси" />
                    
                    <LinearLayout
                        android:id="@+id/layout_http_upstream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_http_upstream_host"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Хост upstream прокси"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_http_upstream_port"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Порт upstream прокси"
                                android:inputType="number"
                                android:text="8080" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <RadioGroup
                            android:id="@+id/radio_group_http_upstream_protocol"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <RadioButton
                                android:id="@+id/radio_http_upstream_http"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="HTTP"
                                android:checked="true" />
                            <RadioButton
                                android:id="@+id/radio_http_upstream_socks5"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="SOCKS5" />
                        </RadioGroup>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_http_upstream_user"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Логин (опционально)"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:passwordToggleEnabled="true">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_http_upstream_pass"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Пароль (опционально)"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                    
                    <!-- Проверка каскада -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Проверка каскада"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_proxy_healthcheck_host"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Хост или IP для проверки (например, 1.1.1.1)"
                            android:inputType="text"
                            android:text="1.1.1.1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_proxy_healthcheck_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Порт проверки (TCP, напр. 443)"
                            android:inputType="number"
                            android:text="443" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_proxy_healthcheck_interval_sec"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Интервал проверок, сек (минимум 5)"
                            android:inputType="number"
                            android:text="30" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- VPN (SSTP) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_vpn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <LinearLayout
                    android:id="@+id/header_vpn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VPN (SSTP)"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/icon_vpn"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_expand_more"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
                
                <LinearLayout
                    android:id="@+id/content_vpn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="0dp"
                    android:visibility="gone">
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sstp_enabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Включить SSTP" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_host"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Адрес SSTP сервера"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_port"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Порт SSTP"
                            android:inputType="number"
                            android:text="443" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_user"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Логин SSTP"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:passwordToggleEnabled="true">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_pass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Пароль SSTP"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="@string/sstp_tun_mtu_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_tun_mtu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="@string/sstp_tun_mtu_default" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sstp_ignore_cert_errors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Игнорировать ошибки сертификата / self-signed" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sstp_reconnect"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Режим реконнекта SSTP"
                        android:checked="true" />
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_reconnect_delay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Задержка реконнекта, сек"
                            android:inputType="number"
                            android:text="5" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_sstp_reconnect_attempts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Попыток реконнекта"
                            android:inputType="number"
                            android:text="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sstp_connection_logging"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/sstp_log_enable" />
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_share_sstp_log"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:enabled="false"
                        android:text="@string/sstp_log_share" />
                    
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Общие настройки -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <LinearLayout
                    android:id="@+id/header_general"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Общие настройки"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/icon_general"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_expand_more"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
                
                <LinearLayout
                    android:id="@+id/content_general"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="0dp"
                    android:visibility="gone">
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_auto_update_check"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/settings_auto_update_check" />
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Язык интерфейса"
                        android:layout_marginTop="16dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <RadioGroup
                        android:id="@+id/radio_group_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <RadioButton
                            android:id="@+id/radio_ru"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Русский" />
                        <RadioButton
                            android:id="@+id/radio_en"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="English" />
                    </RadioGroup>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
    </LinearLayout>
</ScrollView>
